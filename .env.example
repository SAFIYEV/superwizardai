# OpenRouter API key
OPENROUTER_API_KEY=

# Supabase (фронтенд, префикс VITE_) — Dashboard → Settings → API
# URL: https://<project-ref>.supabase.co
# Ключ: publishable (sb_publishable_…) или классический anon JWT (eyJ…), если с publishable ошибки
VITE_SUPABASE_URL=https://dfostzoumcoqsnylauhe.supabase.co
VITE_SUPABASE_ANON_KEY=
#
# Authentication → URL Configuration: Site URL + Redirect URLs, например:
#   http://localhost:5173
#   http://127.0.0.1:5173
#   http://localhost:5173/**

# Service role / sb_secret_* (секретный ключ) НИКОГДА не кладите в VITE_* и не вшивайте в React — только на сервере (отдельный backend).
# SUPABASE_SERVICE_ROLE_KEY=

# URL бэкенда с /api (пусто в локальном dev — используется Vite plugin)
# VITE_API_URL=https://your-worker.workers.dev
